# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# IGDB / Twitch — https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Steam Web API — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key-here

# LLM Provider (set at least one — OpenAI is primary, Groq is fallback)
# OpenAI (recommended) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Groq (free fallback) — https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key-here
